meta {
  name: getAll
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/post/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.body?.data?.posts && res.body?.data?.posts?.length > 0) {
    bru.setVar('firstPostId', res.body.data.posts[0]._id);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

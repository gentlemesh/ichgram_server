meta {
  name: addCommentForPost
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/comment/{{firstPostId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "text": "Это комментарий к первому посту"
  }
}

script:post-response {
  if (res.body?.data?.comments && res.body?.data?.comments?.length > 0) {
    bru.setVar('firstCommentId', res.body.data.comments[0]._id);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
